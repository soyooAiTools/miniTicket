NODE_ENV=development
PORT=3000
TARO_APP_API_BASE_URL=https://beta.example.com/api
# 仅在本地联调小程序时打开；开启后会绕过真实的 requestPayment。
TARO_APP_MOCK_WECHAT_PAY=false

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ticketing
REDIS_URL=redis://localhost:6379

JWT_SECRET=change-me
ADMIN_API_SECRET=change-me-admin-secret
# 后台受保护的 API 路由会在服务端校验 x-admin-secret / ADMIN_API_SECRET。
# 管理后台前端默认请求同域 /api；如果要切到其他环境，只需在浏览器 localStorage 里设置 ticketing.admin.apiBaseUrl。
# 当前 admin workbench 不再读取 ticketing.admin.apiSecret。
VIEWER_ID_CARD_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
# 兼容旧配置：目前也接受 PII_KEY。

# 小程序登录与微信支付
# WECHAT_APP_ID / WECHAT_APP_SECRET 用于 POST /api/auth/wechat/login。
WECHAT_APP_ID=your-wechat-app-id
WECHAT_APP_SECRET=your-wechat-miniapp-secret
# 仅限非生产环境。设置后，API 会跳过 jscode2session，直接复用这个 open id。
WECHAT_DEV_LOGIN_OPEN_ID=
WECHAT_MCH_ID=your-wechat-merchant-id
WECHAT_MCH_CERT_SERIAL_NO=your-wechat-merchant-cert-serial
WECHAT_API_V3_KEY=your-wechat-pay-api-v3-key
WECHAT_PLATFORM_CERT_SERIAL_NO=your-wechat-platform-cert-serial
WECHAT_PLATFORM_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
# WECHAT_NOTIFY_URL 必须指向 POST /api/payments/wechat/callback。
WECHAT_NOTIFY_URL=https://beta.example.com/api/payments/wechat/callback
# 当前实现使用平台证书和 API v3 key 校验微信回调。
# WECHAT_CALLBACK_SECRET 仅预留给后续加固，当前回调路由不会读取它。
WECHAT_CALLBACK_SECRET=replace-me
WECHAT_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# 仅限非生产环境。开启后，API 会返回 mock JSAPI 并在本地标记订单已支付。
WECHAT_PAY_DEV_MOCK=false

# 上游出票 / 退款提交对接
VENDOR_API_BASE_URL=https://vendor.example.com/api
VENDOR_API_KEY=replace-me
# 仅限非生产环境。开启后，上游出票 / 退款调用会返回确定性的 mock 编号。
VENDOR_DEV_MOCK=false
# 上游回调需要携带 x-vendor-callback-secret：
# - POST /api/fulfillment/vendor-callback-issued
# - POST /api/refunds/vendor-callback
VENDOR_CALLBACK_SECRET=replace-me

# Beta 运营开关保存在数据库中的后台活动配置里，不在 env 里直接开关。
# 目前的行为只用于尽力而为的运营指引：
# - published 会把活动从公开目录和详情里隐藏
# - saleStatus 和 refundEntryEnabled 目前驱动后台/用户侧状态展示
# 它们还不是 draft 下单或退款提交的强制服务端总开关。
