NODE_ENV=development
PORT=3000
TARO_APP_API_BASE_URL=https://beta.example.com/api
# Set true only for local miniapp联调 when you want to bypass real requestPayment.
TARO_APP_MOCK_WECHAT_PAY=false

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ticketing
REDIS_URL=redis://localhost:6379

JWT_SECRET=change-me
ADMIN_API_SECRET=change-me-admin-secret
# Admin guarded API routes require x-admin-secret matching ADMIN_API_SECRET.
# The admin SPA reads this from browser localStorage key ticketing.admin.apiSecret.
# Set ticketing.admin.apiBaseUrl too if the admin app must target a non-default API base.
VIEWER_ID_CARD_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
# Legacy compatibility: PII_KEY is also accepted for now.

# Miniapp auth + WeChat Pay
# WECHAT_APP_ID / WECHAT_APP_SECRET drive POST /api/auth/wechat/login.
WECHAT_APP_ID=your-wechat-app-id
WECHAT_APP_SECRET=your-wechat-miniapp-secret
# Non-production only. When set, the API will skip jscode2session and reuse this open id.
WECHAT_DEV_LOGIN_OPEN_ID=
WECHAT_MCH_ID=your-wechat-merchant-id
WECHAT_MCH_CERT_SERIAL_NO=your-wechat-merchant-cert-serial
WECHAT_API_V3_KEY=your-wechat-pay-api-v3-key
WECHAT_PLATFORM_CERT_SERIAL_NO=your-wechat-platform-cert-serial
WECHAT_PLATFORM_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
# WECHAT_NOTIFY_URL must resolve to POST /api/payments/wechat/callback.
WECHAT_NOTIFY_URL=https://beta.example.com/api/payments/wechat/callback
# Current implementation verifies WeChat callbacks with the platform cert and API v3 key.
# WECHAT_CALLBACK_SECRET is reserved for future hardening and is not read by the callback route today.
WECHAT_CALLBACK_SECRET=replace-me
WECHAT_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# Non-production only. When true, API returns a mock JSAPI intent and marks the order paid locally.
WECHAT_PAY_DEV_MOCK=false

# Vendor upstream submit/refund integration
VENDOR_API_BASE_URL=https://vendor.example.com/api
VENDOR_API_KEY=replace-me
# Non-production only. When true, upstream submit/refund calls return deterministic mock refs locally.
VENDOR_DEV_MOCK=false
# Vendor callbacks must send x-vendor-callback-secret to:
# - POST /api/fulfillment/vendor-callback-issued
# - POST /api/refunds/vendor-callback
VENDOR_CALLBACK_SECRET=replace-me

# Beta operational switches live in the database-backed admin event controls, not env vars.
# Current behavior is best-effort operational guidance:
# - published removes the event from public catalog/detail reads
# - saleStatus and refundEntryEnabled currently drive admin/customer-facing state
# They are not yet full server-side kill switches for draft-order creation or refund submission.
