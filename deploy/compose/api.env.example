# Server-side API environment for the beta deployment.
# This file is documentation only; docker-compose.beta.yml reads:
# /srv/ticketing-beta/shared/.env

NODE_ENV=production
PORT=3000

DATABASE_URL=postgresql://postgres:postgres@postgres:5432/ticketing
REDIS_URL=redis://redis:6379

JWT_SECRET=change-me
ADMIN_API_SECRET=change-me-admin-secret
VIEWER_ID_CARD_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
# Legacy compatibility: PII_KEY is also accepted for now.

# Miniapp auth + WeChat Pay
WECHAT_APP_ID=your-wechat-app-id
WECHAT_APP_SECRET=your-wechat-miniapp-secret
WECHAT_DEV_LOGIN_OPEN_ID=
WECHAT_MCH_ID=your-wechat-merchant-id
WECHAT_MCH_CERT_SERIAL_NO=your-wechat-merchant-cert-serial
WECHAT_API_V3_KEY=your-wechat-pay-api-v3-key
WECHAT_PLATFORM_CERT_SERIAL_NO=your-wechat-platform-cert-serial
WECHAT_PLATFORM_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
WECHAT_NOTIFY_URL=https://beta.example.com/api/payments/wechat/callback
# WECHAT_CALLBACK_SECRET is reserved for future hardening and is not read by the callback route today.
WECHAT_CALLBACK_SECRET=replace-me
WECHAT_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
WECHAT_PAY_DEV_MOCK=false

# Vendor upstream submit/refund integration
VENDOR_API_BASE_URL=https://vendor.example.com/api
VENDOR_API_KEY=replace-me
VENDOR_CALLBACK_SECRET=replace-me
